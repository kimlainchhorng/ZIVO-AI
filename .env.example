# Environment Variables Example

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=ZIVO AI
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Existing ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
NODE_ENV=development
NEXT_PUBLIC_API_URL=https://api.example.com
LOG_LEVEL=info
MAX_TOKENS=150
MODEL=gpt-3.5-turbo

# ── Search ────────────────────────────────────────────────────────────────────
SEARCH_API_KEY=your_search_api_key

# ── Analytics ─────────────────────────────────────────────────────────────────
ANALYTICS_SECRET=your_analytics_secret

# ── Voice ─────────────────────────────────────────────────────────────────────
VOICE_API_KEY=your_voice_api_key

# ── Blockchain ────────────────────────────────────────────────────────────────
BLOCKCHAIN_RPC_URL=https://mainnet.infura.io/v3/your_key

# ── ML ────────────────────────────────────────────────────────────────────────
ML_API_KEY=your_ml_api_key

# ── Monitoring ────────────────────────────────────────────────────────────────
MONITORING_WEBHOOK=https://your-monitoring-webhook.com

# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://localhost:5432/zivo
S3_BUCKET=your-s3-bucket

# ── Workflow ──────────────────────────────────────────────────────────────────
WORKFLOW_WEBHOOK_SECRET=your_webhook_secret