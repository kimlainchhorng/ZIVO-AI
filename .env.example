# Environment Variables Example

# OpenAI API Key (required - used for chat, site generation, and DALL-E 3 image generation)
OPENAI_API_KEY=your_openai_api_key

# Node Environment
NODE_ENV=development

# Public API URL
NEXT_PUBLIC_API_URL=https://api.example.com

# Log Level
LOG_LEVEL=info

# Maximum Tokens
MAX_TOKENS=150

# Model
MODEL=gpt-3.5-turbo

# ── Multimedia Generation ─────────────────────────────────────────────────────

# Runway ML API Key (optional - used for text-to-video generation)
RUNWAY_API_KEY=your_runway_api_key

# Supabase (optional - used for persistent media storage and CDN delivery)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=media

# ElevenLabs (optional - used for voice-over generation in videos)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Replicate (optional - Stable Diffusion fallback for image generation)
REPLICATE_API_KEY=your_replicate_api_key