{
  "expo": {
    "name": "ZIVO Mobile",
    "slug": "zivo-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "zivo",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0b14",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zivo.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0b14"
      },
      "package": "com.zivo.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
